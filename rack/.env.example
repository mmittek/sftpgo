# Domain for ACME/Let's Encrypt and cert filenames
ACME_DOMAIN=your-domain.example.com
ACME_EMAIL=you@example.com

# VPN IP to bind admin UI to (keeps admin off the public internet)
ADMIN_BIND_IP=10.8.0.5

# Host paths
STORAGEPOOL_PATH=/mnt/storagepool
DATA_PATH=/srv/sftpgo/data

# Run as this user (must match owner of DATA_PATH)
SFTPGO_UID=1000
SFTPGO_GID=1000
